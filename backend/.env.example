# ============================================================
# CNN Unified App — Variables de entorno (desarrollo local)
# Copiar a .env y completar con tus valores reales:
#   cp .env.example .env
# ============================================================

# ── Seguridad ─────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esta_clave_por_una_generada_con_32_chars

# ── Supabase ──────────────────────────────────────────────
# Obtener en: supabase.com -> tu proyecto -> Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...    # anon/public key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key (NUNCA exponer al frontend)

# ── Modelos YOLO ──────────────────────────────────────────
# Archivos en la carpeta backend/models/ (descargar con: python download_models.py)
# Opciones: yolov8n.pt | yolov8s.pt | yolov8m.pt | yolov8l.pt | yolov8x.pt
YOLO_OBJECT_MODEL=yolov8n.pt

# Modelo especifico para deteccion de rostros (1 clase: face)
# Fuente: https://github.com/akanametov/yolo-face
YOLO_FACE_MODEL=yolov8n-face.pt

# ── DeepFace ──────────────────────────────────────────────
# Modelo de reconocimiento facial. Se descarga en ~/.deepface/weights/
# Opciones y tamanos:
#   VGG-Face   -> 4096D embeddings | ~514 MB | alta precision (recomendado)
#   Facenet512 -> 512D  embeddings | ~89 MB  | muy alta precision
#   ArcFace    -> 512D  embeddings | ~261 MB | excelente para produccion
#   OpenFace   -> 128D  embeddings | ~30 MB  | rapido y liviano
FACE_MODEL=VGG-Face

# Backend de deteccion de DeepFace (para registro de nuevas personas)
# Opciones: opencv | retinaface | mtcnn | ssd | mediapipe
# retinaface y mtcnn son mas precisos pero mas lentos
FACE_DETECTOR=opencv

# ── Umbrales ──────────────────────────────────────────────
# Confianza minima YOLO (0.1 = detecta casi todo, 0.9 = solo muy seguros)
CONFIDENCE_THRESHOLD=0.5

# Distancia maxima para considerar un match facial como verificado
# Menor = mas estricto. Rango tipico: 0.30 (estricto) a 0.50 (permisivo)
SIMILARITY_THRESHOLD=0.40

# Maximo de objetos a detectar por imagen
MAX_DETECTIONS=100
